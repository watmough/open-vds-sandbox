macro(BuildZlib)
  if (WIN32)
    list(APPEND ZLIB_LIBS_LIST_RELEASE "lib/zlibstatic$<$<CONFIG:Debug>:d>.lib")
#    list(APPEND ZLIB_LIBS_LIST_RELEASE "lib/zlib$<$<CONFIG:Debug>:d>.lib")
#    list(APPEND ZLIB_DLLS_LIST_RELEASE "bin/zlib$<$<CONFIG:Debug>:d>.dll")
  elseif (APPLE)
    list(APPEND ZLIB_LIBS_LIST_RELEASE "lib/libz.a")
  else()
    list(APPEND ZLIB_LIBS_LIST_RELEASE "lib/libz.a")
  endif()

  GetRootInstallDir(ZLIB_ROOT_INSTALL zlib ${zlib_VERSION})
  get_property(_isMultiConfig GLOBAL PROPERTY GENERATOR_IS_MULTI_CONFIG)
  if (_isMultiConfig)
    set(ZLIB_INST "${ZLIB_ROOT_INSTALL}/$<CONFIG>")
  else()
    set(ZLIB_INST "${ZLIB_ROOT_INSTALL}/${CMAKE_BUILD_TYPE}")
  endif()

  set(ZLIB_INSTALL_INC_DIR ${ZLIB_INST}/include)
  set(ZLIB_INSTALL_LIB_DIR ${ZLIB_INST}/lib)
  set(EXTRA_CMAKE_ARGS "-DINSTALL_BIN_DIR=${ZLIB_INST}/bin;-DINSTALL_LIB_DIR=${ZLIB_INSTALL_LIB_DIR};-DINSTALL_INC_DIR=${ZLIB_INSTALL_INC_DIR}")
  list(APPEND EXTRA_CMAKE_ARGS "-DBUILD_SHARED_LIBS=OFF")
  list(APPEND EXTRA_CMAKE_ARGS "-DCMAKE_POSITION_INDEPENDENT_CODE=ON")
  list(APPEND EXTRA_CMAKE_ARGS "-DCMAKE_POLICY_VERSION_MINIMUM=3.5")
  BuildExternal(zlib ${zlib_VERSION} "" ${zlib_SOURCE_DIR} "${ZLIB_LIBS_LIST_RELEASE}" "${ZLIB_DLLS_LIST_RELEASE}" ON "${EXTRA_CMAKE_ARGS}")
endmacro()

