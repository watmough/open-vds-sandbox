macro(BuildCrc32c)
  if (WIN32)
  list(APPEND CRC32C_LIBS_LIST "lib/crc32c.lib")
  elseif (APPLE)
  list(APPEND CRC32C_DLLS_LIST "lib/libcrc32c.a")
  else()
  list(APPEND CRC32C_DLLS_LIST "lib${LIBSUFFIX}/libcrc32c.a")
  endif()

  list(APPEND CMAKE_ARGS "-DCMAKE_POSITION_INDEPENDENT_CODE=ON")
  list(APPEND CMAKE_ARGS "-DBUILD_SHARED_LIBS=OFF")
  list(APPEND CMAKE_ARGS "-DCRC32C_BUILD_TESTS=OFF")
  list(APPEND CMAKE_ARGS "-DCRC32C_BUILD_BENCHMARKS=OFF")
  list(APPEND CMAKE_ARGS "-DCRC32C_USE_GLOG=OFF")
  if (NOT WIN32)
  list(APPEND CMAKE_ARGS "-DCMAKE_CXX_FLAGS=-Wno-address")
  endif()
  BuildExternal(crc32c ${crc32c_VERSION} "" ${crc32c_SOURCE_DIR} "${CRC32C_LIBS_LIST}" "${CRC32C_DLLS_LIST}" ON "${CMAKE_ARGS}")
endmacro()
