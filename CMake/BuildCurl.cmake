function(BuildCurl)
  if (NOT BUILD_CURL)
    return()
  endif()
  if (WIN32)
    set(PLATFORM_OPTIONS ";-DCURL_USE_SCHANNEL=ON")
    list(APPEND CURL_LIBS_LIST_RELEASE "lib/libcurl$<$<CONFIG:Debug>:-d>.lib")
    #list(APPEND CURL_DLLS_LIST_RELEASE "bin/libcurl$<$<CONFIG:Debug>:-d>.dll")
  elseif(APPLE)
    set(PLATFORM_OPTIONS ";-DCURL_CA_BUNDLE=none;-DCURL_CA_PATH=none;-DCURL_CA_FALLBACK=ON")
    list(APPEND CURL_DLLS_LIST_RELEASE "lib/libcurl$<$<CONFIG:Debug>:-d>.a")
  else()
    set(PLATFORM_OPTIONS ";-DCURL_CA_BUNDLE=none;-DCURL_CA_PATH=none;-DCURL_CA_FALLBACK=ON")
    #list(APPEND CURL_DLLS_LIST_RELEASE "lib${LIBSUFFIX}/libcurl$<$<CONFIG:Debug>:-d>.so")
    list(APPEND CURL_DLLS_LIST_RELEASE "lib${LIBSUFFIX}/libcurl$<$<CONFIG:Debug>:-d>.a")
  endif()

  list(APPEND PLATFORM_OPTIONS "-DCMAKE_POSITION_INDEPENDENT_CODE=ON")

  if (OPENSSL_ROOT_DIR)
    list(APPEND PLATFORM_OPTIONS "-DOPENSSL_ROOT_DIR=${OPENSSL_ROOT_DIR}")
  endif()
  if (OPENSSL_USE_STATIC_LIBS)
    list(APPEND PLATFORM_OPTIONS "-DOPENSSL_USE_STATIC_LIBS=ON")
  endif()

  list(APPEND PLATFORM_OPTIONS "-DBUILD_SHARED_LIBS=OFF")
  list(APPEND PLATFORM_OPTIONS "-DCURL_USE_LIBSSH2=OFF")
  BuildExternal(curl ${curl_VERSION} "" ${curl_SOURCE_DIR} "${CURL_LIBS_LIST_RELEASE}" "${CURL_DLLS_LIST_RELEASE}" ON "-DBUILD_CURL_EXE=OFF;-DHTTP_ONLY=ON;-DBUILD_TESTING=OFF${PLATFORM_OPTIONS}")
  set(curl_root ${curl_INSTALL_INT_CONFIG}/lib/cmake/CURL PARENT_SCOPE)
  set(curl_INSTALL_INT_CONFIG ${curl_INSTALL_INT_CONFIG} PARENT_SCOPE)
  set(curl_INSTALL_LIBRARY "${curl_INSTALL_INT_CONFIG}/${CURL_LIBS_LIST_RELEASE}" PARENT_SCOPE)
endfunction()

